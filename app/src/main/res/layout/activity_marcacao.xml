<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    tools:context=".MarcacaoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvJogador1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOGADOR 1:"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etJogador1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NOME DO JOGADOR"
            android:textSize="24dp"
            android:gravity="left"
            android:inputType="textPersonName" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPlacar1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="0"
        android:textSize="48sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutBtJogadorUm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisUmOnClick"
            android:text="+1" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisTresOnClick"
            android:text="+3" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisSeisOnClick"
            android:text="+6" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisDozeOnClick"
            android:text="+12" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvJogador2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOGADOR 2:"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etJogador2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NOME DO JOGADOR"
            android:textSize="24dp"
            android:gravity="left"
            android:inputType="textPersonName" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPlacar2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="0"
        android:textSize="48sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisUmJogador2OnClick"
            android:text="+1" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisTresJogador2OnClick"
            android:text="+3" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisSeisJogador2OnClick"
            android:text="+6" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:onClick="btMaisDozeJogador2OnClick"
            android:text="+12" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btHistorico"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:onClick="btHistoricoOnClick"
            android:padding="16dp"
            android:text="Histórico Jogadas" />

        <Button
            android:id="@+id/btZerar"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:padding="16dp"

            android:onClick="btZerarOnClick"
            android:text="Zerar Placar" />

        <Button
            android:id="@+id/btInformar"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:onClick="btInformarNomes"
            android:text="Informar Nomes" />
    </LinearLayout>
</LinearLayout>
